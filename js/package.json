{
  "name": "@schematichq/schematic-js",
  "version": "1.4.1",
  "main": "dist/schematic.cjs.js",
  "module": "dist/schematic.esm.js",
  "types": "dist/schematic.d.ts",
  "exports": {
    ".": {
      "types": "./dist/schematic.d.ts",
      "development": {
        "require": "./dist/schematic.dev.cjs.js",
        "import": "./dist/schematic.dev.esm.js"
      },
      "production": {
        "require": "./dist/schematic.prod.cjs.js",
        "import": "./dist/schematic.prod.esm.js"
      },
      "default": {
        "require": "./dist/schematic.prod.cjs.js",
        "import": "./dist/schematic.prod.esm.js"
      }
    }
  },
  "files": [
    "dist/schematic.dev.cjs.js",
    "dist/schematic.dev.esm.js",
    "dist/schematic.prod.cjs.js",
    "dist/schematic.prod.esm.js",
    "dist/schematic.browser.js",
    "dist/schematic.d.ts"
  ],
  "author": "Schematic <engineering@schematichq.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/SchematicHQ/schematic-js.git"
  },
  "scripts": {
    "dev": "npx esbuild src/index.ts --bundle --format=esm --outfile=dist/schematic.esm.js --watch",
    "build": "./version.sh && npx tsc && yarn clean && yarn build:browser && yarn build:cjs:dev && yarn build:cjs:prod && yarn build:esm:dev && yarn build:esm:prod && yarn build:types",
    "build:browser": "npx esbuild src/browser.ts --bundle --minify --outfile=dist/schematic.browser.js --platform=browser --define:__DEV__=false",
    "build:cjs:dev": "npx esbuild src/index.ts --bundle --format=cjs --outfile=dist/schematic.dev.cjs.js --define:__DEV__=true",
    "build:cjs:prod": "npx esbuild src/index.ts --bundle --format=cjs --outfile=dist/schematic.prod.cjs.js --define:__DEV__=false",
    "build:esm:dev": "npx esbuild src/index.ts --bundle --format=esm --outfile=dist/schematic.dev.esm.js --define:__DEV__=true",
    "build:esm:prod": "npx esbuild src/index.ts --bundle --format=esm --outfile=dist/schematic.prod.esm.js --define:__DEV__=false",
    "build:types": "npx tsc && npx api-extractor run",
    "clean": "rm -rf dist",
    "format": "prettier --write src/*.ts",
    "lint": "eslint src --report-unused-disable-directives --fix",
    "openapi": "rm -rf src/types/api/ && npx openapi-generator-cli generate -c openapi-config.yaml && prettier --write \"src/types/api/**/*.{ts,tsx}\"",
    "prepare": "husky",
    "test": "vitest run",
    "test:reactnative": "vitest run --config vitest.config.reactnative.ts",
    "test:watch": "vitest",
    "tsc": "npx tsc"
  },
  "dependencies": {
    "cross-fetch": "^4.1.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@microsoft/api-extractor": "^7.58.7",
    "@openapitools/openapi-generator-cli": "^2.34.0",
    "@vitest/browser": "^4.1.7",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "mock-socket": "^9.3.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.7"
  },
  "resolutions": {
    "rollup": ">=4.59.0",
    "undici": ">=7.24.0"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
