{
  "name": "@schematichq/schematic-dev-toolbar",
  "version": "1.0.0",
  "main": "dist/schematic-dev-toolbar.cjs.js",
  "module": "dist/schematic-dev-toolbar.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/schematic-dev-toolbar.cjs.js",
    "dist/schematic-dev-toolbar.esm.js",
    "dist/index.d.ts"
  ],
  "author": "Schematic <engineering@schematichq.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/SchematicHQ/schematic-js.git"
  },
  "scripts": {
    "build": "npx tsc && yarn clean && yarn build:cjs && yarn build:esm && yarn build:types",
    "build:cjs": "npx esbuild src/index.ts --bundle --format=cjs --outfile=dist/schematic-dev-toolbar.cjs.js --external:@schematichq/schematic-js",
    "build:esm": "npx esbuild src/index.ts --bundle --format=esm --outfile=dist/schematic-dev-toolbar.esm.js --external:@schematichq/schematic-js",
    "build:types": "npx tsc --declaration --emitDeclarationOnly --outDir dist",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@schematichq/schematic-js": "^1.2.15"
  },
  "devDependencies": {
    "esbuild": "^0.27.1",
    "typescript": "^5.9.3"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
