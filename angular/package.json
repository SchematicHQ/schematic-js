  "scripts": {
    "build": "./version.sh && yarn format && yarn lint && ng-packagr -p ng-package.json",
    "build:watch": "ng-packagr -p ng-package.json --watch",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint src --ext ts --report-unused-disable-directives --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "dependencies": {
    "@schematichq/schematic-js": "^1.4.0"
  },
  "devDependencies": {
    "@angular/compiler": "^21.2.0",
