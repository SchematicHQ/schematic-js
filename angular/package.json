{
  "name": "@schematichq/schematic-angular",
  "version": "1.0.0",
  "main": "dist/schematic-angular.cjs.js",
  "module": "dist/schematic-angular.esm.js",
  "types": "dist/schematic-angular.d.ts",
  "exports": {
    ".": {
      "types": "./dist/schematic-angular.d.ts",
      "import": "./dist/schematic-angular.esm.js",
      "require": "./dist/schematic-angular.cjs.js"
    }
  },
  "files": [
    "dist/schematic-angular.cjs.js",
    "dist/schematic-angular.esm.js",
    "dist/schematic-angular.d.ts"
  ],
  "author": "Schematic <engineering@schematichq.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/SchematicHQ/schematic-js.git"
  },
  "scripts": {
    "dev": "yarn tsc --watch",
    "build": "./version.sh && yarn tsc && yarn format && yarn lint && yarn clean && yarn build:cjs && yarn build:esm && yarn build:types",
    "build:cjs": "npx esbuild src/index.ts --bundle --external:@angular/core --external:rxjs --format=cjs --outfile=dist/schematic-angular.cjs.js",
    "build:esm": "npx esbuild src/index.ts --bundle --external:@angular/core --external:rxjs --format=esm --outfile=dist/schematic-angular.esm.js",
    "build:types": "npx tsc && npx api-extractor run",
    "clean": "rm -rf dist",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint src --ext ts --report-unused-disable-directives --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "tsc": "npx tsc",
    "prepare": "husky"
  },
  "dependencies": {
    "@schematichq/schematic-js": "^1.3.1"
  },
  "devDependencies": {
    "@angular/compiler": "^19.2.0",
    "@angular/core": "^19.2.0",
    "@eslint/js": "^10.0.1",
    "@microsoft/api-extractor": "^7.58.2",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.2",
    "rxjs": "^7.8.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "@angular/core": ">=16.0.0",
    "rxjs": ">=7.0.0"
  },
  "resolutions": {
    "minimatch": ">=3.1.3"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
