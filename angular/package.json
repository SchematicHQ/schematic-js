    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "ng-packagr": "^21.2.0",
    "prettier": "^3.8.2",
    "rxjs": "^7.8.0",
    "tslib": "^2.8.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "@angular/core": ">=19.0.0",
    "rxjs": ">=7.0.0"
  },
